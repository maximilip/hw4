<!DOCTYPE html>
<html>
  <head>
    <title>Tacostagram Final</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <div class="container mt-3">
      <% if flash["notice"] %>
        <div class="alert alert-info">
          <%= flash["notice"] %>
        </div>
      <% end %>

      <nav class="d-flex justify-content-between align-items-center py-2 border-bottom">
        <div>
          <a href="/" class="text-decoration-none">Home</a>
        </div>
        <div class="nav-right d-flex gap-2 align-items-center">
          <% if @current_user %>
            <span><%= @current_user.username %></span>
            <a href="/logout" class="btn btn-outline-secondary">Logout</a>
          <% else %>
            <a href="/login" class="btn btn-outline-primary">Login</a>
            <a href="/users/new" class="btn btn-primary">Signup</a>
          <% end %>
        </div>
      </nav>

      <main class="mt-4">
        <%= yield %>
      </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </body>
</html>
