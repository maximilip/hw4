<h1><%= @place["name"] %></h1>

<div class="mt-3">
  <p>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Post</a>
  </p>

<div class="row">
  <% for entry in @entries %>
    <div class="col-md-6 col-lg-4 mb-4">
      <div class="card h-100 shadow-sm">
        <% if entry.uploaded_image.attached? %>
          <img src="<%= url_for(entry.uploaded_image) %>" class="card-img-top" alt="<%= entry.title %>">
        <% end %>
        <div class="card-body">
          <h3 class="card-title h5 text-primary">
            <a href="/entries/<%= entry["id"] %>" class="text-decoration-none"><%= entry["title"] %></a>
          </h3>
          <h4 class="card-subtitle mb-2 text-muted h6"><%= entry["occurred_on"] %></h4>
          <p class="card-text"><%= truncate(entry["description"], length: 100) %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

  <p>
    <a href="/places" class="btn btn-link">Back to All Places</a>
  </p>
</div>
